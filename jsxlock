import React, { useRef, useState } from 'react';
import { TouchableWithoutFeedback, View, StyleSheet } from 'react-native';
import LottieView from 'lottie-react-native';

const LockButton = () => {
  const animationRef = useRef(null);
  const [isLocked, setIsLocked] = useState(true);

  const toggleLock = () => {
    if (isLocked) {
      // Déverrouillage : frames 45 → 63
      animationRef.current?.play(45, 63);
    } else {
      // Verrouillage : frames 105 → 117
      animationRef.current?.play(105, 117);
    }
    setIsLocked(!isLocked);
  };

  return (
    <TouchableWithoutFeedback onPress={toggleLock}>
      <View style={styles.container}>
        <LottieView
          ref={animationRef}
          source={require('./assets/animations/Lock_red.json')}
          style={styles.animation}
          autoPlay={false}
          loop={false}
          speed={1.2}
        />
      </View>
    </TouchableWithoutFeedback>
  );
};

const styles = StyleSheet.create({
  container: {
    width: 150,
    height: 150,
    justifyContent: 'center',
    alignItems: 'center',
  },
  animation: {
    width: '100%',
    height: '100%',
  },
});

export default LockButton;
